# Handle line endings automatically
* text=auto

# Unity YAML files - force LF to avoid spurious diffs
*.cs text eol=lf
*.unity text eol=lf
*.asset text eol=lf
*.prefab text eol=lf
*.meta text eol=lf
*.json text eol=lf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.fbx binary
*.wav binary
*.mp3 binary